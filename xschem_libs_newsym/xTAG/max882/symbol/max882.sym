G {type=regulator
format="@spiceprefix@name @pinlist @symname"

tedax_format="footprint @name @footprint
device @name @symname"

template="name=U1 device=MAX882 footprint=SO8"}
V {}
S {}
E {}
L 4 -200 -40 -160 -40 {}
L 4 -200 0 -160 0 {}
L 4 -200 40 -160 40 {}
L 7 160 -40 200 -40 {}
L 7 160 40 200 40 {}
L 9 -120 100 -120 140 {}
L 9 80 100 80 140 {}
L 9 120 100 120 140 {}
B 5 -202.5 -42.5 -197.5 -37.5 {show_pinname=true name_dx=51 name_dy=-9.6 name_size=0.4 name=STBY_ dir=in pinnumber=7}
B 5 -202.5 -2.5 -197.5 2.5 {show_pinname=true name_dx=51 name_dy=-9.6 name_size=0.4 name=IN dir=in pinnumber=5}
B 5 -202.5 37.5 -197.5 42.5 {show_pinname=true name_dx=51 name_dy=-9.6 name_size=0.4 name=LBI dir=in pinnumber=8}
B 5 197.5 -42.5 202.5 -37.5 {show_pinname=true name_dx=-51 name_dy=-9.6 name_size=0.4 name_flip=1 name=LBO dir=out pinnumber=1}
B 5 197.5 37.5 202.5 42.5 {show_pinname=true name_dx=-51 name_dy=-9.6 name_size=0.4 name_flip=1 name=OUT dir=out pinnumber=4}
B 5 -122.5 137.5 -117.5 142.5 {show_pinname=true name_dx=-21 name_dy=-51 name_size=0.4 name_rot=2 name_flip=1 name=SET dir=inout pinnumber=2}
B 5 77.5 137.5 82.5 142.5 {show_pinname=true name_dx=-1 name_dy=-51 name_size=0.4 name_rot=2 name_flip=1 name=GND dir=inout pinnumber=3}
B 5 117.5 137.5 122.5 142.5 {show_pinname=false name_dx=-25 name_dy=-5 name_size=0.2 name_flip=1 name=GND dir=inout pinnumber=6}
P 4 5 -160 -100 160 -100 160 100 -160 100 -160 -100 {}
T {7} -172 -56 0 1 0.25 0.25 {layer=13}
T {5} -172 -16 0 1 0.25 0.25 {layer=13}
T {8} -172 24 0 1 0.25 0.25 {layer=13}
T {1} 172 -56 0 0 0.25 0.25 {layer=13}
T {4} 172 24 0 0 0.25 0.25 {layer=13}
T {2} -136 112 3 1 0.25 0.25 {layer=13}
T {3} 64 112 3 1 0.25 0.25 {layer=13}
T {6} 104 112 3 1 0.25 0.25 {layer=13}
T {@device} -63 -18 0 0 0.6 0.6 {}
T {@name} 160 -143 0 1 0.6 0.6 {}
