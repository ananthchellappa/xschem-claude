# Claude suggestions : 

# zoom with Ctrl+wheel
xschem bind wheel up   ctrl canvas view.zoom_in
xschem bind wheel down ctrl canvas view.zoom_out
# vertical pan with plain wheel
xschem bind wheel up   0    canvas view.pan_up
xschem bind wheel down 0    canvas view.pan_down
# (Shift+wheel already pans horizontally — view.pan_left/right — by default, no change needed)
# Alt+wheel : grow / shrink every selected object -- wire thickness, and the [N:M] bus
# suffix on a pin/netlabel net name or an instance name. The actions are registered in
# C (edit.grow_selection / edit.shrink_selection -> busresize_apply, utils/bus_resize.tcl);
# rebind to any chord, e.g. `xschem bind wheel up ctrl+shift canvas edit.grow_selection`.
# See doc/claude/specs/bus_thickness_scroll.md.
xschem bind wheel up   alt canvas edit.grow_selection
xschem bind wheel down alt canvas edit.shrink_selection
# Alt+Shift+wheel : transpose the single [N] bus index on a selected pin/netlabel name
# or instance name (wires/text tolerated, no effect). something -> something[0] ->
# something[1]; down steps back, [0] -> something. See bus_transpose_scroll.md.
xschem bind wheel up   alt+shift canvas edit.transpose_grow_selection
xschem bind wheel down alt+shift canvas edit.transpose_shrink_selection

# Cadence-style instantiation: the "i" key opens the Create Instance browser
# (Edit > Create Instance). `break` stops the event reaching the generic <KeyPress>
# -> C dispatcher, which otherwise maps 'i' to descend-into-symbol.
bind .drw <Key-i> {xschem create_instance; break}

# Cadence-style net highlighting (see doc/claude/specs/net_hilight_styles.md):
#   9 : highlight net. If a net/wire/label is selected, highlight it (advancing the
#       style each time, leaving the selection intact); otherwise enter highlight mode
#       and click nets/labels to highlight, ESC to end.
#   8 : remove a specific net highlight (noun-verb on the selection, or click-to-remove
#       mode otherwise).
#   0 : remove ALL net highlights.
# `break` stops the digit reaching the C dispatcher (where 0 toggles pin logic level).
bind .drw <Key-9> {xschem hilight_net_interactive;   break}
bind .drw <Key-8> {xschem unhilight_net_interactive; break}
bind .drw <Key-0> {xschem unhilight_all;             break}

# Alt-minus : step the highlight STYLE cursor back one (wrapping). The cursor
# auto-advances after each highlight; this re-applies a recently used style to the
# next highlight. Bound for both the main-row minus and the numeric-keypad minus.
# See doc/claude/specs/hilight_style_decrement.md.
bind .drw <Alt-Key-minus>       {cadence::prev_hilight_style; break}
bind .drw <Alt-Key-KP_Subtract> {cadence::prev_hilight_style; break}

# --------------------------------------------------------------------------
# Cadence-style key bindings (library navigation + hierarchy).
# See doc/claude/specs/cadence_bindkey_plan.md. Pure Tcl, no C changes: each bind lives on
# .drw and ends in `break`, so it captures the chord before the generic
# <KeyPress> -> C dispatcher sees it. Five of these chords are claimed by the C
# dispatcher (Save as Symbol, Clear symbol, Cut, Edit-in-new-window, Crosshair);
# the `break` overrides them. Those commands remain on their menus; optional
# replacement key bindings are listed (commented out) at the end.
# --------------------------------------------------------------------------

# Helper procs (utils/), path-resolved relative to this rc file.
set _ut [file join [file dirname [file normalize [info script]]] .. utils]
source [file join $_ut lib_mgr_helpers.tcl]
source [file join $_ut cadence_nav.tcl]
source [file join $_ut cadence_clip.tcl]
source [file join $_ut hilight_style_nav.tcl]
source [file join $_ut bus_resize.tcl]
source [file join $_ut bus_transpose.tcl]
source [file join $_ut text_resize.tcl]
source [file join $_ut apply_hilight.tcl]
# moved unset _ut

# Ctrl-Alt-S : locate a cell in the Library Manager. Acts on the selected instance's
# master, or (nothing selected) the cell being viewed, or a "lib/cell" text note.
bind .drw <Control-Alt-Key-s>   {locate_selected_in_libmgr;       break}
# Ctrl-Alt-N : place the current Library-Manager selection
bind .drw <Control-Alt-Key-n>   {place_libmgr_selection;          break}
# Ctrl-N : open a NEW blank editor window (untitled.sch scratchpad), leaving the current
# schematic untouched. Overrides the default Ctrl-N = Clear Schematic (still on File menu).
bind .drw <Control-Key-n>       {cadence::new_blank_window;       break}
# Ctrl-Shift-N : open a schematic read-only in a NEW window -- the selected instance's,
# or the cell named by a "lib/cell" text note.
bind .drw <Control-Shift-Key-N> {cadence::open_inst_sch_readonly; break}
# Ctrl-X : descend into selected instance's schematic (no-op if none selected)
bind .drw <Control-Key-x>       {cadence::descend_into_inst;      break}
# Ctrl-E : return one level. Overrides the C default (go_back / ascend in place) with
# the window-chain-aware version: a window descended-into-new-window returns focus to
# the PARENT window instead of ascending the child in place (issue 0053). Cloned to
# every new/detached canvas by clone_canvas_bindings, so it works in child windows too.
bind .drw <Control-Key-e>       {cadence::return_one_level;       break}
# Alt-E : return to top of hierarchy, remembering where we were (per window)
bind .drw <Alt-Key-e>           {cadence::return_to_top;          break}
# Alt-X : descend back into the location remembered by the last Alt-E
bind .drw <Alt-Key-x>           {cadence::descend_to_last;        break}
# Alt-Shift-C : capture lib/cell/view to the clipboard + CIW. Selected instance ->
# its master's L/C/V; selected text note -> the first "a/b/c" slash path in it;
# nothing selected -> the current cellview's L/C/V. GOTCHA (same as Ctrl-Shift-2/N
# above): with Shift held the "c" key emits the capital "C" keysym, so bind Key-C.
bind .drw <Alt-Shift-Key-C>     {cadence::capture_lcv;            break}
# Ctrl-Alt-D : round-trip a deep location through a text note. Nothing selected ->
# write the last Alt-E location as a "inst/inst/..." note you place; a note that starts
# with such a path -> descend there (same engine as Alt-X).
bind .drw <Control-Alt-Key-d>   {cadence::deeploc_note;           break}
# Ctrl-2 / Ctrl-Shift-2 : make the current view Editable / Read Only.
# GOTCHA: with Shift held, the number-row "2" key emits its SHIFTED keysym, not
# "2" -- so <Control-Shift-Key-2> never matches. On a US layout Shift-2 is "@"
# (keysym "at"), so Ctrl-Shift-2 must be bound via <Control-Key-at>. The Key-2 form
# is kept as a fallback for layouts where Shift-2 stays "2". On a non-US layout
# replace "at" with whatever your Shift-2 produces (run `xev` to find the keysym).
bind .drw <Control-Key-2>       {cadence::make_editable;          break}
bind .drw <Control-Key-at>      {cadence::make_readonly;          break}
bind .drw <Control-Shift-Key-2> {cadence::make_readonly;          break}

# Descend opens the child schematic READ-ONLY by default (browse mode). To edit,
# press Ctrl-2 after descending, use the "Descend schematic (edit)" right-click
# item, or View > Toggle Read Only.
set descend_readonly 1

